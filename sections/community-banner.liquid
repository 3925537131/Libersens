<section class="section section--flush community-banner">
  {% if section.settings.image != blank %}
    <img src="{{ section.settings.image | image_url: width: 2600 }}" alt="{{ section.settings.image.alt | escape }}" loading="lazy" width="2600" height="1100">
  {% else %}
    <img src="{{ 'libersens-hero.png' | asset_url }}" alt="Libersens community banner placeholder" loading="lazy" width="1792" height="1024">
  {% endif %}

  <div class="container">
    <div class="community-banner__content">
      <h2>{{ section.settings.heading_line_1 }}</h2>
      <p>{{ section.settings.heading_line_2 }}</p>
      <h2>{{ section.settings.heading_line_3 }}</h2>
      {% if section.settings.button_label != blank %}
        <div class="section-actions">
          <a class="button" href="{{ section.settings.button_link | default: '/pages/about-us' }}">{{ section.settings.button_label }}</a>
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Community banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "heading_line_1",
      "label": "Heading line 1",
      "default": "Let's build"
    },
    {
      "type": "text",
      "id": "heading_line_2",
      "label": "Heading line 2",
      "default": "libersens"
    },
    {
      "type": "text",
      "id": "heading_line_3",
      "label": "Heading line 3",
      "default": "together"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Join the community"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Community banner"
    }
  ]
}
{% endschema %}
