<section class="section section--flush slider-section">
  <div class="lib-slider" data-slider>
    <div class="lib-slider__track" data-slider-track>
      {% for block in section.blocks %}
        {% assign fallback_image = 'libersens-product-line.png' %}
        {% if block.settings.fallback_asset == 'wearable' %}
          {% assign fallback_image = 'libersens-product-wearable.png' %}
        {% elsif block.settings.fallback_asset == 'lifestyle' %}
          {% assign fallback_image = 'libersens-lifestyle.png' %}
        {% elsif block.settings.fallback_asset == 'hero' %}
          {% assign fallback_image = 'libersens-hero.png' %}
        {% endif %}
        <article class="lib-slider__slide" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            <img src="{{ block.settings.image | image_url: width: 1600 }}" alt="{{ block.settings.image.alt | escape }}" loading="lazy" width="1600" height="1000">
          {% else %}
            <img src="{{ fallback_image | asset_url }}" alt="{{ block.settings.heading | escape }}" loading="lazy" width="1254" height="1254">
          {% endif %}
          {% if block.settings.eyebrow != blank or block.settings.heading != blank %}
            <div class="lib-slider__caption">
              {% if block.settings.eyebrow != blank %}
                <p class="eyebrow">{{ block.settings.eyebrow }}</p>
              {% endif %}
              {% if block.settings.heading != blank %}
                <h2>{{ block.settings.heading }}</h2>
              {% endif %}
            </div>
          {% endif %}
        </article>
      {% endfor %}
    </div>

    <button class="slider-arrow slider-arrow--prev" type="button" data-slider-prev aria-label="Previous slide">&#8249;</button>
    <button class="slider-arrow slider-arrow--next" type="button" data-slider-next aria-label="Next slide">&#8250;</button>
    <div class="slider-dots" data-slider-dots></div>
  </div>
</section>

{% schema %}
{
  "name": "Image slider",
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "select",
          "id": "fallback_asset",
          "label": "Fallback image",
          "default": "product-line",
          "options": [
            { "value": "product-line", "label": "Product line" },
            { "value": "wearable", "label": "Wearable" },
            { "value": "lifestyle", "label": "Lifestyle" },
            { "value": "hero", "label": "Hero" }
          ]
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow",
          "default": "Libersens"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Private care, beautifully stored."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image slider",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
