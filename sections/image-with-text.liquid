<section class="section image-with-text-section image-with-text-section--{{ section.settings.color_scheme | default: 'light' }}">
  <div class="section__color-wrapper">
    <div class="container">
      <div class="split-feature {% if section.settings.image_position == 'right' %}split-feature--reverse{% endif %}">
        <div class="split-feature__media">
          {% if section.settings.image != blank %}
            <img src="{{ section.settings.image | image_url: width: 1400 }}" alt="{{ section.settings.image.alt | escape }}" loading="lazy" width="1400" height="1000">
          {% else %}
            <img src="{{ 'libersens-lifestyle.png' | asset_url }}" alt="Libersens private self-care still life" loading="lazy" width="1792" height="1024">
          {% endif %}
        </div>

        <div class="split-feature__content">
          <p class="eyebrow">{{ section.settings.eyebrow }}</p>
          <h2>{{ section.settings.heading }}</h2>
          <div class="split-feature__text">{{ section.settings.text }}</div>

          <ul class="feature-list">
            {% for block in section.blocks %}
              <li {{ block.shopify_attributes }}><span>{{ forloop.index }}</span>{{ block.settings.text }}</li>
            {% endfor %}
          </ul>

          {% if section.settings.button_label != blank %}
            <div class="section-actions">
              <a class="button button--secondary" href="{{ section.settings.button_link | default: routes.all_products_collection_url }}">{{ section.settings.button_label }}</a>
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Image with text",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "default": "left",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "light",
      "options": [
        { "value": "light", "label": "Light" },
        { "value": "dark", "label": "Dark" }
      ]
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Designed for real life"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Discretion is part of the experience."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>From low-noise motors to travel-friendly storage, Libersens products are built for the intimate details that matter.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Explore essentials"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "blocks": [
    {
      "type": "point",
      "name": "Point",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Body-safe materials with a soft matte finish."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image with text",
      "blocks": [
        { "type": "point" },
        { "type": "point" },
        { "type": "point" }
      ]
    }
  ]
}
{% endschema %}
