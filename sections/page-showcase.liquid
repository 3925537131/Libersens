  ],
  "blocks": [
    {
      "type": "highlight",
      "name": "Highlight",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "select",
          "id": "fallback_asset",
          "label": "Fallback image",
          "default": "product-line",
          "options": [
            { "value": "product-line", "label": "Product line" },
            { "value": "wearable", "label": "Wearable" },
            { "value": "lifestyle", "label": "Lifestyle" },
            { "value": "hero", "label": "Hero still life" }
          ]
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Featured"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Libersens Essential"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "A discreet product card with thoughtful placeholder copy."
        },
        {
          "type": "text",
          "id": "price",
          "label": "Price",
          "default": "$89.00"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Shop now"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    },
    {
      "type": "point",
      "name": "Detail point",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Discreet by default"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Private packaging, simple care, and storage-forward design."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Page showcase",
      "blocks": [
        { "type": "highlight" },
        { "type": "highlight" },
        { "type": "highlight" },
        { "type": "point" },
        { "type": "point" },
        { "type": "point" }
      ]
