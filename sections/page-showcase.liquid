      "default": "Designed for private confidence."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Thoughtfully designed intimacy products with discreet storage, soft-touch finishes, and routines that feel easy to return to."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "text",
      "id": "grid_eyebrow",
      "label": "Grid eyebrow",
      "default": "Explore"
    },
    {
      "type": "text",
      "id": "grid_heading",
      "label": "Grid heading",
      "default": "Choose the ritual that fits you."
    },
    {
      "type": "text",
      "id": "panel_eyebrow",
      "label": "Panel eyebrow",
      "default": "Details"
    },
    {
      "type": "text",
      "id": "panel_heading",
      "label": "Panel heading",
      "default": "Built around comfort, privacy, and care."
    },
    {
      "type": "richtext",
      "id": "panel_text",
      "label": "Panel text",
      "default": "<p>Each Libersens page is designed like a guided product experience: clear choices first, practical details next, and no awkward guessing.</p>"
    },
    {
      "type": "checkbox",
      "id": "show_page_content",
