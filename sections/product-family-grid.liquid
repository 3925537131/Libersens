<section class="section section--flush product-family-grid">
  {% for block in section.blocks %}
    {% assign fallback_image = 'libersens-product-line.png' %}
    {% if block.settings.fallback_asset == 'wearable' %}
      {% assign fallback_image = 'libersens-product-wearable.png' %}
    {% elsif block.settings.fallback_asset == 'lifestyle' %}
      {% assign fallback_image = 'libersens-lifestyle.png' %}
    {% elsif block.settings.fallback_asset == 'hero' %}
      {% assign fallback_image = 'libersens-hero.png' %}
    {% endif %}

    <article class="family-tile" {{ block.shopify_attributes }}>
      {% if block.settings.image != blank %}
        <img src="{{ block.settings.image | image_url: width: 1400 }}" alt="{{ block.settings.image.alt | escape }}" loading="lazy" width="1400" height="1200">
      {% else %}
        <img src="{{ fallback_image | asset_url }}" alt="{{ block.settings.heading | escape }}" loading="lazy" width="1254" height="1254">
      {% endif %}

      <div class="family-tile__content family-tile__content--{{ block.settings.content_position }}">
        <h2>{{ block.settings.heading }}</h2>
        <p>{{ block.settings.text }}</p>
        <div class="product-banner__actions">
          {% if block.settings.primary_label != blank %}
            <a class="button button--small" href="{{ block.settings.primary_link | default: routes.all_products_collection_url }}">{{ block.settings.primary_label }}</a>
          {% endif %}
          {% if block.settings.secondary_label != blank %}
            <a class="button button--small button--ghost" href="{{ block.settings.secondary_link | default: routes.all_products_collection_url }}">{{ block.settings.secondary_label }}</a>
          {% endif %}
        </div>
      </div>
    </article>
  {% endfor %}
</section>

{% schema %}
{
  "name": "Product family grid",
  "blocks": [
    {
      "type": "tile",
      "name": "Tile",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "select",
          "id": "fallback_asset",
          "label": "Fallback image",
          "default": "product-line",
          "options": [
            { "value": "product-line", "label": "Product line" },
            { "value": "wearable", "label": "Wearable" },
            { "value": "lifestyle", "label": "Lifestyle" },
            { "value": "hero", "label": "Hero" }
          ]
        },
        {
          "type": "select",
          "id": "content_position",
          "label": "Content position",
          "default": "bottom",
          "options": [
            { "value": "top", "label": "Top" },
            { "value": "bottom", "label": "Bottom" }
          ]
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Libersens Curve"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "A focused product family tile with clear calls to action."
        },
        {
          "type": "text",
          "id": "primary_label",
          "label": "Primary button label",
          "default": "Buy now >"
        },
        {
          "type": "url",
          "id": "primary_link",
          "label": "Primary button link"
        },
        {
          "type": "text",
          "id": "secondary_label",
          "label": "Secondary button label",
          "default": "Learn more"
        },
        {
          "type": "url",
          "id": "secondary_link",
          "label": "Secondary button link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product family grid",
      "blocks": [
        { "type": "tile" },
        { "type": "tile" },
        { "type": "tile" },
        { "type": "tile" }
      ]
    }
  ]
}
{% endschema %}
