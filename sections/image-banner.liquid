{% assign fallback_image = 'libersens-lifestyle.png' %}
{% if section.settings.fallback_asset == 'hero' %}
  {% assign fallback_image = 'libersens-hero.png' %}
{% elsif section.settings.fallback_asset == 'product-line' %}
  {% assign fallback_image = 'libersens-product-line.png' %}
{% elsif section.settings.fallback_asset == 'wearable' %}
  {% assign fallback_image = 'libersens-product-wearable.png' %}
{% endif %}
{% assign has_content = false %}
{% if section.settings.eyebrow != blank or section.settings.heading != blank or section.settings.text != blank or section.settings.button_label != blank %}
  {% assign has_content = true %}
{% endif %}

<section class="banner {% unless has_content %}banner--image-only{% endunless %}">
  {% if section.settings.image != blank %}
    <img src="{{ section.settings.image | image_url: width: 2400 }}" alt="{{ section.settings.image.alt | escape }}" loading="lazy" width="2400" height="1200">
  {% else %}
    <img src="{{ fallback_image | asset_url }}" alt="Libersens lifestyle placeholder" loading="lazy" width="1792" height="1024">
  {% endif %}

  {% if has_content %}
    <div class="container">
      <div class="banner__content">
        {% if section.settings.eyebrow != blank %}
          <p class="eyebrow">{{ section.settings.eyebrow }}</p>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h2>{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.text != blank %}
          <p style="margin-top: 14px;">{{ section.settings.text }}</p>
        {% endif %}
        {% if section.settings.button_label != blank %}
          <div class="section-actions">
            <a class="button" href="{{ section.settings.button_link | default: routes.all_products_collection_url }}">{{ section.settings.button_label }}</a>
          </div>
        {% endif %}
      </div>
    </div>
  {% endif %}
</section>

{% schema %}
{
  "name": "Image banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "fallback_asset",
      "label": "Fallback image",
      "default": "lifestyle",
      "options": [
        { "value": "lifestyle", "label": "Lifestyle" },
        { "value": "hero", "label": "Hero" },
        { "value": "product-line", "label": "Product line" },
        { "value": "wearable", "label": "Wearable" }
      ]
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Private by design"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Made to live beautifully in your space."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Elegant forms, storage-forward details, and packaging that looks at home with your self-care essentials."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Discover the collection"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Image banner"
    }
  ]
}
{% endschema %}
