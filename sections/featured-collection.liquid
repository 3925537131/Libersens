{% assign collection = collections[section.settings.collection] %}

<section class="section featured-collection-section">
  <div class="section__color-wrapper">
    <div class="container">
    <div class="section-heading">
      {% if section.settings.eyebrow != blank %}
        <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2>{{ section.settings.heading }}</h2>
      {% endif %}
    </div>

    <div class="product-grid">
      {% if collection != blank and collection.products.size > 0 %}
        {% for product in collection.products limit: section.settings.product_limit %}
          {% render 'product-card', product: product, placeholder_index: forloop.index0 %}
        {% endfor %}
      {% else %}
        {% if section.settings.placeholder_set == 'accessories' %}
          {% assign placeholder_titles = 'Libersens Care Pouch|Libersens Charging Dock|Libersens Cleanse Spray|Libersens Silk Storage Set|Libersens Travel Case|Libersens USB-C Cable|Libersens Drying Cloth|Libersens Care Refill' | split: '|' %}
          {% assign placeholder_prices = '$34.00|$39.00|$22.00|$49.00|$42.00|$18.00|$16.00|$19.00' | split: '|' %}
        {% else %}
          {% assign placeholder_titles = 'Libersens Signature Set|Libersens Curve|Libersens Wearable|Libersens Travel Kit|Libersens Duo Set|Libersens Personal Essential|Libersens Travel Set|Libersens Private Ritual Box' | split: '|' %}
          {% assign placeholder_prices = '$129.00|$89.00|$109.00|$59.00|$129.00|$89.00|$59.00|$149.00' | split: '|' %}
        {% endif %}
        {% for placeholder_title in placeholder_titles limit: section.settings.product_limit %}
          {% assign placeholder_price = placeholder_prices[forloop.index0] %}
          {% render 'product-card', placeholder_index: forloop.index0, placeholder_title: placeholder_title, placeholder_price: placeholder_price %}
        {% endfor %}
      {% endif %}
    </div>

    {% if section.settings.button_label != blank %}
      <div class="section-actions">
        <a class="button button--outline" href="{% if collection != blank %}{{ collection.url }}{% else %}{{ routes.all_products_collection_url }}{% endif %}">{{ section.settings.button_label }}</a>
      </div>
    {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured collection",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Best sellers"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Customer-loved intimacy essentials."
    },
    {
      "type": "range",
      "id": "product_limit",
      "label": "Products to show",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "placeholder_set",
      "label": "Placeholder set",
      "default": "products",
      "options": [
        { "value": "products", "label": "Products" },
        { "value": "accessories", "label": "Accessories" }
      ]
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "View collection"
    }
  ],
  "presets": [
    {
      "name": "Featured collection"
    }
  ]
}
{% endschema %}
