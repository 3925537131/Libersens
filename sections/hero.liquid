<section class="hero section--flush {% if section.settings.eyebrow == blank and section.settings.heading == blank and section.settings.text == blank %}hero--minimal{% endif %}">
  {% if section.settings.image != blank %}
    <img class="hero__image" src="{{ section.settings.image | image_url: width: 2800 }}" alt="{{ section.settings.image.alt | escape }}" width="2800" height="1400">
  {% else %}
    <img class="hero__image" src="{{ 'libersens-hero.png' | asset_url }}" alt="Libersens intimacy wellness product still life" width="1792" height="1024">
  {% endif %}

  <div class="container">
    <div class="hero__content">
      {% if section.settings.eyebrow != blank %}
        <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h1>{{ section.settings.heading }}</h1>
      {% endif %}
      {% if section.settings.text != blank %}
        <p>{{ section.settings.text }}</p>
      {% endif %}
      {% if section.settings.primary_label != blank or section.settings.secondary_label != blank %}
        <div class="hero__actions">
          {% if section.settings.primary_label != blank %}
            <a class="button" href="{{ section.settings.primary_link | default: routes.all_products_collection_url }}">{{ section.settings.primary_label }}</a>
          {% endif %}
          {% if section.settings.secondary_label != blank %}
            <a class="button button--outline" href="{{ section.settings.secondary_link | default: '/pages/about-us' }}">{{ section.settings.secondary_label }}</a>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Female intimacy, thoughtfully designed"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Quiet luxury for your most private rituals."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Libersens creates elegant intimacy products that feel discreet, comfortable, and easy to make your own."
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Shop Libersens"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "Our approach"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
