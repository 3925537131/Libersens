<section class="section brand-intro">
  <div class="section__color-wrapper">
    <div class="container">
      <div class="content-box content-box--medium content-box--text-center content-box--center text-container">
        {% if section.settings.eyebrow != blank %}
          <h2 class="heading heading--small">{{ section.settings.eyebrow }}</h2>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h3 class="heading h2">{{ section.settings.heading }}</h3>
        {% endif %}
        {% if section.settings.text != blank %}
          <div class="brand-intro__text">{{ section.settings.text }}</div>
        {% endif %}
        {% for block in section.blocks %}
          {% if block.settings.text != blank %}
            <p {{ block.shopify_attributes }}><strong>{{ block.settings.text }}</strong></p>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Rich text",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Welcome to"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "libersens"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text"
    }
  ],
  "blocks": [
    {
      "type": "line",
      "name": "Line",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Private by design"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Rich text",
      "blocks": [
        { "type": "line" },
        { "type": "line" },
        { "type": "line" }
      ]
    }
  ]
}
{% endschema %}
