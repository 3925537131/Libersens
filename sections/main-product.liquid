<section class="section">
  <div class="container">
    {% if product != blank %}
      {% assign current_variant = product.selected_or_first_available_variant %}
      <div class="product-page">
        <div class="product-gallery">
          {% if product.media.size > 1 %}
            <div class="product-thumbs">
              {% for media in product.media limit: 9 %}
                {% assign preview_image = media.preview_image %}
                {% if preview_image == blank and media.media_type == 'image' %}
                  {% assign preview_image = media %}
                {% endif %}
                <button type="button" class="product-thumb{% if forloop.first %} is-active{% endif %}" aria-label="View {{ media.alt | default: product.title | escape }}">
                  {% if preview_image != blank %}
                    <img
                      data-gallery-thumb
                      data-gallery-full="{{ preview_image | image_url: width: 1400 }}"
                      src="{{ preview_image | image_url: width: 240 }}"
                      alt="{{ media.alt | default: product.title | escape }}"
                      width="240"
                      height="240"
                    >
                  {% endif %}
                </button>
              {% endfor %}
            </div>
          {% endif %}

          <div class="product-gallery__main">
            {% if product.featured_image != blank %}
              <img
                data-gallery-main
                src="{{ product.featured_image | image_url: width: 1400 }}"
                alt="{{ product.featured_image.alt | default: product.title | escape }}"
                width="1400"
                height="1400"
              >
            {% else %}
              <img data-gallery-main src="{{ 'libersens-product-line.png' | asset_url }}" alt="{{ product.title | escape }}" width="1200" height="1200">
            {% endif %}
          </div>
        </div>

        <div class="product-info">
          {% if product.vendor != blank %}
            <p class="eyebrow">{{ product.vendor }}</p>
          {% endif %}
          <h1 class="product-info__title">{{ product.title }}</h1>
          <div class="price product-info__price">
            {{ current_variant.price | money }}
            {% if current_variant.compare_at_price > current_variant.price %}
              <span class="compare-price">{{ current_variant.compare_at_price | money }}</span>
            {% endif %}
          </div>

          <hr class="product-info__divider">

          {% form 'product', product, class: 'product-form' %}
            {% unless product.has_only_default_variant %}
              <div class="field product-info__options">
                <label for="ProductVariant-{{ section.id }}">Options</label>
                <select id="ProductVariant-{{ section.id }}" name="id">
                  {% for variant in product.variants %}
                    <option value="{{ variant.id }}" {% if variant == current_variant %}selected{% endif %} {% unless variant.available %}disabled{% endunless %}>
                      {{ variant.title }} - {{ variant.price | money }}
                    </option>
                  {% endfor %}
                </select>
              </div>
            {% else %}
              <input type="hidden" name="id" value="{{ current_variant.id }}">
            {% endunless %}

            <div class="product-info__quantity">
              <label for="Quantity-{{ section.id }}">Quantity:</label>
              <div class="quantity-selector" data-quantity-selector>
                <button type="button" class="quantity-selector__btn" data-quantity-minus aria-label="Decrease quantity">
                  {% render 'icon', icon: 'minus' %}
                </button>
                <input class="quantity-input" id="Quantity-{{ section.id }}" type="number" name="quantity" min="1" value="1" data-quantity-input>
                <button type="button" class="quantity-selector__btn" data-quantity-plus aria-label="Increase quantity">
                  {% render 'icon', icon: 'plus' %}
                </button>
              </div>
            </div>

            <button class="button button--full product-info__add" type="submit" {% unless product.available %}disabled{% endunless %}>
              {% if product.available %}Add to cart{% else %}Sold out{% endif %}
            </button>

            {{ form | payment_button }}
          {% endform %}

          {% assign share_url = product.url | prepend: shop.url %}
          {% assign share_text = product.title | url_encode %}
          <div class="product-share">
            <span class="product-share__label">Share</span>
            <a class="product-share__link" href="https://www.facebook.com/sharer.php?u={{ share_url | url_encode }}" target="_blank" rel="noopener" aria-label="Share on Facebook">
              {% render 'icon', icon: 'facebook' %}
            </a>
            <a class="product-share__link" href="https://pinterest.com/pin/create/button/?url={{ share_url | url_encode }}&media={{ product.featured_image | image_url: width: 1200 | url_encode }}&description={{ share_text }}" target="_blank" rel="noopener" aria-label="Pin on Pinterest">
              {% render 'icon', icon: 'pinterest' %}
            </a>
            <a class="product-share__link" href="https://twitter.com/intent/tweet?url={{ share_url | url_encode }}&text={{ share_text }}" target="_blank" rel="noopener" aria-label="Share on X">
              {% render 'icon', icon: 'twitter' %}
            </a>
            <a class="product-share__link" href="https://t.me/share/url?url={{ share_url | url_encode }}&text={{ share_text }}" target="_blank" rel="noopener" aria-label="Share on Telegram">
              {% render 'icon', icon: 'telegram' %}
            </a>
          </div>

          {% if product.description != blank %}
            <div class="rte product-info__description">{{ product.description }}</div>
          {% endif %}
        </div>
      </div>
    {% else %}
      <div class="empty-state">
        <h1>Product unavailable</h1>
        <p>This product is not available right now.</p>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Main product",
  "settings": []
}
{% endschema %}
