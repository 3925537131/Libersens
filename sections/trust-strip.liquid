<section class="trust-strip">
  <div class="container trust-strip__inner">
    {% for block in section.blocks %}
      <div {{ block.shopify_attributes }}>{{ block.settings.text }}</div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Trust strip",
  "blocks": [
    {
      "type": "item",
      "name": "Item",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Discreet shipping"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust strip",
      "blocks": [
        { "type": "item" },
        { "type": "item" },
        { "type": "item" },
        { "type": "item" }
      ]
    }
  ]
}
{% endschema %}
