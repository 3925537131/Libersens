<section class="section section--flush product-banner-stack">
  {% for block in section.blocks %}
    {% assign fallback_image = 'libersens-hero.png' %}
    {% if block.settings.fallback_asset == 'product-line' %}
      {% assign fallback_image = 'libersens-product-line.png' %}
    {% elsif block.settings.fallback_asset == 'wearable' %}
      {% assign fallback_image = 'libersens-product-wearable.png' %}
    {% elsif block.settings.fallback_asset == 'lifestyle' %}
      {% assign fallback_image = 'libersens-lifestyle.png' %}
    {% endif %}

    <article class="product-banner" {{ block.shopify_attributes }}>
      {% if block.settings.image != blank %}
        <img src="{{ block.settings.image | image_url: width: 2600 }}" alt="{{ block.settings.image.alt | escape }}" loading="lazy" width="2600" height="1300">
      {% else %}
        <img src="{{ fallback_image | asset_url }}" alt="{{ block.settings.heading | escape }}" loading="lazy" width="1792" height="1024">
      {% endif %}

      <div class="product-banner__content product-banner__content--{{ block.settings.content_position }}">
        {% if block.settings.heading != blank %}
          <h2>{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.text != blank %}
          <p>{{ block.settings.text }}</p>
        {% endif %}
        <div class="product-banner__actions">
          {% if block.settings.primary_label != blank %}
            <a class="button" href="{{ block.settings.primary_link | default: routes.all_products_collection_url }}">{{ block.settings.primary_label }}</a>
          {% endif %}
          {% if block.settings.secondary_label != blank %}
            <a class="button button--ghost" href="{{ block.settings.secondary_link | default: routes.all_products_collection_url }}">{{ block.settings.secondary_label }}</a>
          {% endif %}
        </div>
      </div>
    </article>
  {% endfor %}
</section>

{% schema %}
{
  "name": "Product banner stack",
  "blocks": [
    {
      "type": "banner",
      "name": "Banner",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "select",
          "id": "fallback_asset",
          "label": "Fallback image",
          "default": "product-line",
          "options": [
            { "value": "hero", "label": "Hero" },
            { "value": "product-line", "label": "Product line" },
            { "value": "wearable", "label": "Wearable" },
            { "value": "lifestyle", "label": "Lifestyle" }
          ]
        },
        {
          "type": "select",
          "id": "content_position",
          "label": "Content position",
          "default": "bottom",
          "options": [
            { "value": "bottom", "label": "Bottom" },
            { "value": "middle", "label": "Middle" }
          ]
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Libersens Signature"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "A full-width product moment built for high-impact merchandising."
        },
        {
          "type": "text",
          "id": "primary_label",
          "label": "Primary button label",
          "default": "BUY NOW >"
        },
        {
          "type": "url",
          "id": "primary_link",
          "label": "Primary button link"
        },
        {
          "type": "text",
          "id": "secondary_label",
          "label": "Secondary button label",
          "default": "Learn more"
        },
        {
          "type": "url",
          "id": "secondary_link",
          "label": "Secondary button link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product banner stack",
      "blocks": [
        { "type": "banner" },
        { "type": "banner" },
        { "type": "banner" }
      ]
    }
  ]
}
{% endschema %}
